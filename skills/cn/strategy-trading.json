{
  "schemaVersion": "1.0",
  "id": "strategy-trading",
  "version": "1.0.0",
  "name": {
    "cn": "策略交易",
    "en": "Strategy Trading"
  },
  "description": {
    "cn": "把交易想法转成可执行策略、风险约束和下单计划；连接券商后可进入模拟或实盘执行。",
    "en": "Turn a trading idea into an executable strategy, risk policy, and order plan; connect a broker to run paper or live execution."
  },
  "author": {
    "name": "community"
  },
  "icon": {
    "type": "emoji",
    "value": "1f4c8"
  },
  "tags": ["trading", "strategy", "execution", "risk", "automation"],
  "category": "finance",
  "visibility": {
    "scope": "public"
  },
  "launch": {
    "type": "chat"
  },
  "instructions": {
    "type": "inline",
    "content": "你是策略交易助手。把用户的交易想法转成可执行策略、风险约束和下单计划。先收集市场、标的、周期、资金规模、最大回撤、仓位上限、止损/止盈规则，以及执行模式（模拟/实盘）。输出固定为：策略摘要、入场/退出规则、仓位与风控、订单计划、需要的数据和券商连接器。没有券商连接器时，只生成 dry-run 计划，不要伪造下单结果；只有在用户明确确认实盘且连接器可用时才执行。信息不足时，只追问最关键的一项。"
  },
  "starters": [
    "把这套交易想法整理成可执行策略。",
    "基于这个标的和风险预算，生成模拟盘执行计划。",
    "把这个策略拆成入场、止损、止盈和下单步骤。"
  ],
  "model": {
    "syncGlobalConfig": false,
    "params": {
      "temperature": 0.2,
      "max_tokens": 6000,
      "presence_penalty": 0,
      "frequency_penalty": 0,
      "sendMemory": true,
      "historyMessageCount": 12,
      "compressMessageLengthThreshold": 2500
    }
  },
  "tools": [],
  "mcp": {
    "servers": [
      {
        "id": "paper-broker",
        "name": "Paper Broker",
        "transport": "stdio",
        "required": false
      }
    ]
  },
  "ui": {
    "entryLabel": {
      "cn": "策略交易",
      "en": "Strategy Trading"
    },
    "emptyState": "guided"
  },
  "permissions": {
    "network": true,
    "filesystem": false,
    "wallet": false,
    "externalTools": ["paper-broker"],
    "dataScopes": ["market-data", "portfolio", "orders"]
  },
  "compatibility": {
    "appVersion": ">=0.1.0",
    "mcp": "optional"
  },
  "release": {
    "status": "published",
    "review": "approved"
  }
}
